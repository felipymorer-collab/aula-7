#include <stdio.h>

int menor(int a, int b) {
    if (a < b) {
        return a;
    } else {
        return b;
    }
}

int main() {
    int x, y, z, resultado;

    printf("Digite tres numeros inteiros:\n");
    scanf("%d %d %d", &x, &y, &z);

    resultado = menor(menor(x, y), z);

    printf("O menor numero eh: %d\n", resultado);

    return 0;
}
