#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int numero() {
    return rand() % 10;
}

int main() {
    int a, b, resposta, resultado;

    srand(time(NULL));

    a = numero();
    b = numero();

    printf("Quanto eh %d + %d? ", a, b);
    scanf("%d", &resposta);

    resultado = a + b;

    if (resposta == resultado) {
        printf("Correto!\n");
    } else {
        printf("Errado! O resultado correto eh %d\n", resultado);
    }

    return 0;
}
